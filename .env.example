# Database connection override (SQLAlchemy URL)
# DATABASE_URL=postgresql://user:password@localhost:5432/letterboxd

# Optional: Letterboxd session cookies if authenticated scraping becomes necessary
# Copy from your browser's Application > Cookies panel (e.g., lb_session=abc123).
# LETTERBOXD_SESSION_COOKIE="lb_session=abc123"

# Scraper tuning overrides
# Copy your browser UA if Letterboxd blocks default requests.
# SCRAPER_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 14_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
# SCRAPER_MAX_CONCURRENCY=4
# SCRAPER_THROTTLE_SECONDS=1.0
